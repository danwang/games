{
  "name": "games-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/games/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,green \"npm --workspace @games/platform-server run dev\" \"npm --workspace @games/platform-web run dev\"",
    "build": "npm --workspace @games/platform-web run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck:server": "tsc -p ./apps/server/tsconfig.json --pretty false --noEmit",
    "typecheck:web": "tsc -p ./apps/web/tsconfig.json --pretty false --noEmit",
    "typecheck:sdk": "tsc -p ./packages/game-sdk/tsconfig.json --pretty false --noEmit",
    "typecheck:registry": "tsc -p ./packages/game-registry/tsconfig.json --pretty false --noEmit",
    "typecheck:lost-cities": "tsc -p ./packages/games/lost-cities/tsconfig.json --pretty false --noEmit",
    "typecheck:splendor": "tsc -p ./packages/games/splendor/tsconfig.json --pretty false --noEmit"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "vitest": "^3.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.8",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
